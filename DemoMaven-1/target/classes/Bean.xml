<?xml version="1.0" encoding="UTF-8"?>

<beans xmlns = "http://www.springframework.org/schema/beans"
   xmlns:xsi = "http://www.w3.org/2001/XMLSchema-instance"
   xsi:schemaLocation = "http://www.springframework.org/schema/beans
   http://www.springframework.org/schema/beans/spring-beans-3.0.xsd">
   
   
   <bean id="item1" class="SpringCore4.hexaware.Anotation4.Items" scope="singleton">
    <property name="itemId" value="1"/>
    <property name="itemName" value="Laptop"/>
    <property name="price" value="75000"/>
</bean>

<bean id="item2" class="SpringCore4.hexaware.Anotation4.Items" scope="prototype">
    <property name="itemId" value="2"/>
    <property name="itemName" value="Mobile"/>
    <property name="price" value="20000"/>
</bean>

</beans>